# EVote Configuration
# Copy to .env.local and fill in the values

# Required: NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-here
AUTH_URL=http://localhost:3000

# DB_DRIVER=json (default, uses /data/*.json files)
# DB_DRIVER=mysql (uses MySQL via Prisma, requires DATABASE_URL)
DB_DRIVER=json

# Optional: Vote encryption key
VOTE_ENCRYPTION_KEY=your-encryption-key-here

# For MySQL adapter (optional):
# DATABASE_URL="mysql://user:password@localhost:3306/evote_transparan"
# Run: npx prisma generate && npx prisma migrate dev
