// Prisma schema for MySQL adapter option
// This is optional - the default is JSON file-based storage (DB_DRIVER=json)
// To use MySQL: set DB_DRIVER=mysql and DATABASE_URL in .env, then:
//   npx prisma generate
//   npx prisma migrate dev
//
// Migration script: scripts/migrate-json-to-mysql.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  username           String   @unique
  passwordHash       String
  roleId             String
  memberId           String?
  mustChangePassword Boolean  @default(false)
  isActive           Boolean  @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  role               Role     @relation(fields: [roleId], references: [id])
}

model Role {
  id          String   @id @default(uuid())
  name        String
  description String?
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
}

model Member {
  id                 String   @id @default(uuid())
  namaLengkap        String
  nomorAnggota       String   @unique
  fotoProfil         String?
  email              String   @unique
  noHP               String?
  organizationUnitId String
  jabatan            String?
  status             String   @default("Aktif")
  tanggalBergabung   DateTime
  tanggalBerakhir    DateTime?
  verificationStatus String   @default("belum")
  nik                String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organizationUnit   OrganizationUnit @relation(fields: [organizationUnitId], references: [id])
}

model OrganizationUnit {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     Member[]
}

model Poll {
  id               String   @id @default(uuid())
  title            String
  description      String?
  type             String
  category         String
  startDate        DateTime
  endDate          DateTime
  status           String   @default("Draft")
  visibility       String   @default("public-after-close")
  quorumPercentage Int      @default(50)
  allowComments    Boolean  @default(true)
  isRankingPublic  Boolean  @default(true)
  randomizeOptions Boolean  @default(false)
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pollOptions      PollOption[]
  pollEligibility  PollEligibility[]
  votes            Vote[]
  voteLogEntries   VoteLogEntry[]
  voteTokens       VoteToken[]
  comments         Comment[]
  reportExports    ReportExport[]
}

model PollOption {
  id          String   @id @default(uuid())
  pollId      String
  name        String
  description String?
  visiMisi    String?
  foto        String?
  urutan      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  poll        Poll     @relation(fields: [pollId], references: [id])
}

model PollEligibility {
  id          String   @id @default(uuid())
  pollId      String
  type        String
  referenceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  poll        Poll     @relation(fields: [pollId], references: [id])
}

model VoteToken {
  id        String   @id @default(uuid())
  token     String   @unique
  pollId    String
  memberId  String
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poll      Poll     @relation(fields: [pollId], references: [id])
  vote      Vote?
}

model Vote {
  id           String   @id @default(uuid())
  pollId       String
  voteTokenId  String   @unique
  optionIds    Json
  ranking      Json?
  hash         String
  receiptHash  String
  timestamp    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  poll         Poll     @relation(fields: [pollId], references: [id])
  voteToken    VoteToken @relation(fields: [voteTokenId], references: [id])
}

model VoteLogEntry {
  id           String   @id @default(uuid())
  pollId       String
  voteId       String
  hash         String
  previousHash String
  data         String
  timestamp    DateTime
  chainIndex   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  poll         Poll     @relation(fields: [pollId], references: [id])
}

model Comment {
  id           String   @id @default(uuid())
  pollId       String
  memberId     String
  content      String
  isHidden     Boolean  @default(false)
  hiddenReason String?
  hiddenBy     String?
  parentId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  poll         Poll     @relation(fields: [pollId], references: [id])
}

model Announcement {
  id                        String   @id @default(uuid())
  title                     String
  content                   String
  targetOrganizationUnitId  String?
  isPinned                  Boolean  @default(false)
  readBy                    Json     @default("[]")
  createdBy                 String
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model CompanyDocument {
  id              String   @id @default(uuid())
  title           String
  description     String?
  filePath        String
  category        String
  acknowledgedBy  Json     @default("[]")
  isRequired      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ReportExport {
  id          String   @id @default(uuid())
  pollId      String
  type        String
  format      String
  filePath    String?
  generatedBy String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  poll        Poll    @relation(fields: [pollId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  before     String?
  after      String?
  ip         String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id                    String   @id @default("settings-1")
  organizationName      String
  organizationLogo      String   @default("/logo.svg")
  activePeriod          String
  defaultTimezone       String   @default("Asia/Jakarta")
  defaultQuorumPercentage Int    @default(50)
  defaultRankingMethod  String   @default("borda")
  voteHashSalt          String
  retentionMappingDays  Int      @default(365)
  allowPublicResultView Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model MemberDocument {
  id          String   @id @default(uuid())
  memberId    String
  jenis       String
  filePath    String
  status      String   @default("belum")
  keterangan  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MemberHistory {
  id          String   @id @default(uuid())
  memberId    String
  field       String
  oldValue    String?
  newValue    String
  changedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
